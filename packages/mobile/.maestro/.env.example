# Copy to .env (which is gitignored) and fill in real values.
# Required by .maestro/run.js.

# App ID for Maestro to launch.
#   - Expo Go on iOS:           host.exp.Exponent
#   - Expo Go on Android:       host.exp.exponent
#   - Standalone dev client:    com.bvolante.pitch-tracker
# Tip: run `npm run e2e:ios` / `e2e:android` and the launcher will set APP_ID for you.
APP_ID=host.exp.Exponent

