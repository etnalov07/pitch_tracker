{
    "name": "@pitch-tracker/marketing",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc --noEmit && vite build",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write \"src/**/*.{ts,tsx,css,html,md}\" \"index.html\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx,css,html,md}\" \"index.html\""
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "react-router-dom": "^7.12.0"
    },
    "devDependencies": {
        "@types/react": "^19.2.8",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.0.5",
        "prettier": "^3.8.0",
        "typescript": "^5.9.3",
        "vite": "^7.1.0"
    }
}
