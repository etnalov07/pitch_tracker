# Marketing site environment variables.
# Copy to `.env.local` for local dev. Set in your hosting provider for prod.

# App Store URLs — when empty, badges render as visually-disabled "Coming Soon".
# Populate at launch.
VITE_APP_STORE_URL=
VITE_PLAY_STORE_URL=

# Web app base URL — used by the "Sign in" CTA in the header.
# Defaults to https://bvolante.com when unset.
VITE_WEB_APP_URL=https://bvolante.com

# Contact email rendered in the footer and About page.
VITE_CONTACT_EMAIL=brian.volante@bvolante.com
