NODE_ENV=test
PORT=5001

# Local Docker Postgres (docker compose up -d)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pitch_tracker_test
DB_USER=bvolante_pitch_tracker
DB_PASSWORD=localdev

# Fake JWT secret — local only, never commit a real one
JWT_SECRET=test-jwt-secret-local-only-not-for-production
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# Email disabled in tests
RESEND_API_KEY=
FROM_EMAIL=test@pitchchart.local
FROM_EMAIL_NAME=PitchChart Test
INVITE_EXPIRY_DAYS=7
